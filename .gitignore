# -----------------------------------------------------------
# Dependencies
# -----------------------------------------------------------
node_modules/

# -----------------------------------------------------------
# Build output (auto-generated by tsup / vite / tsc)
# -----------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# -----------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------
# Logs
# -----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------
# Environment / secrets
# Never commit real env files. Templates (.env.example) are fine.
# -----------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example

# -----------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# -----------------------------------------------------------
# Editor / IDE
# We DO commit .vscode/settings.json (shared workspace TS version).
# Everything else in .vscode/ is personal preference.
# -----------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------
# Bundler / dev-tool caches
# -----------------------------------------------------------
.cache/
.vite/
.turbo/
.parcel-cache/
.rollup.cache/
.eslintcache
.stylelintcache

# -----------------------------------------------------------
# Temp / scratch
# -----------------------------------------------------------
tmp/
.tmp/
temp/

# -----------------------------------------------------------
# Chartly-specific
# -----------------------------------------------------------
# Reference screenshots you drop into the repo root for design chats.
# These are useful during dev but shouldn't ship to git.
image.png
image-*.png
reference*.png
