---
import { Code } from 'astro:components';
import GuideLayout from '../../layouts/GuideLayout.astro';

const title = 'Guide · Chartly';
---

<GuideLayout title={title}>
  <div class="prose-guide">
    <header class="mb-12 border-b border-border pb-8">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-brand-strong">Getting started</p>
      <h1 class="mb-4 text-4xl font-semibold tracking-tight text-text">Introduction</h1>
      <p class="max-w-[720px] text-lg leading-relaxed text-muted">
        Chartly is a composable React charting library built on
        <a href="https://d3js.org/" class="text-text underline decoration-border underline-offset-4 hover:decoration-brand-strong">D3</a>.
        Every chart is a tree of small, typed components you compose together &mdash; there
        is no monolithic <code>&lt;Chart&gt;</code> that takes 40 props. You bring the JSX,
        Chartly brings the math.
      </p>
    </header>

    <section id="installation" class="mb-16 scroll-mt-24">
      <h2 class="mb-4 text-2xl font-semibold text-text">Installation</h2>
      <p class="mb-4">
        Install Chartly from npm. React 18+ is a peer dependency &mdash; it is not
        bundled with the library, so you must have it in your project already.
      </p>
      <Code code={`npm install chartly`} lang="bash" theme="github-dark" />
      <p class="mb-4 mt-6">Or with your preferred package manager:</p>
      <Code code={`pnpm add chartly
yarn add chartly
bun add chartly`} lang="bash" theme="github-dark" />
      <p class="mt-6">
        The package ships in both ESM and CommonJS formats with full TypeScript
        declarations, so it works in modern bundlers (Vite, Next.js, Astro) and
        older Node tooling alike.
      </p>
    </section>

    <section id="first-chart" class="mb-16 scroll-mt-24">
      <h2 class="mb-4 text-2xl font-semibold text-text">Your first chart</h2>
      <p class="mb-4">
        A minimum-viable line chart is three components: a container, an axis pair,
        and a line. The container measures its parent and provides scales via
        React context; children read those scales to draw themselves.
      </p>
      <Code lang="tsx" theme="github-dark" code={`import { ChartContainer, Line, XAxis, YAxis } from "chartly";

const data = [
  { month: "Jan", revenue: 320 },
  { month: "Feb", revenue: 460 },
  { month: "Mar", revenue: 380 },
  { month: "Apr", revenue: 620 },
];

export function RevenueChart() {
  return (
    <div style={{ height: 320 }}>
      <ChartContainer
        data={data}
        xKey="month"
        xScaleType="band"
        yKey="revenue"
        yScaleType="linear"
      >
        <XAxis />
        <YAxis />
        <Line stroke="#5eead4" strokeWidth={2} />
      </ChartContainer>
    </div>
  );
}`} />
      <p class="mt-6">
        Note the wrapping <code>div</code> with an explicit height. Chartly charts
        fill their parent &mdash; they never take a fixed <code>width</code> or
        <code>height</code> prop. This makes them responsive by default, but the
        parent needs to give them a size.
      </p>
    </section>

    <section id="typescript" class="mb-16 scroll-mt-24">
      <h2 class="mb-4 text-2xl font-semibold text-text">TypeScript setup</h2>
      <p class="mb-4">
        Chartly is written in TypeScript and every component is generic over your
        data row type. You get autocomplete on <code>xKey</code>, <code>yKey</code>,
        and render-prop callbacks &mdash; without writing a single type annotation
        of your own.
      </p>
      <Code lang="tsx" theme="github-dark" code={`interface Row {
  month: string;
  revenue: number;
}

<ChartContainer<Row>
  data={data}         // typed as Row[]
  xKey="month"        // autocomplete: "month" | "revenue"
  yKey="revenue"      // narrowed to numeric keys only via KeysOfType
  xScaleType="band"
  yScaleType="linear"
>
  {/* ... */}
</ChartContainer>`} />
      <p class="mt-6">
        The <code>yKey</code> prop uses the internal <code>KeysOfType&lt;T, number&gt;</code>
        utility, so passing a string-valued key is a compile error, not a runtime
        bug. See <a href="/guide/helpers/#keys-of-type" class="text-text underline decoration-border underline-offset-4 hover:decoration-brand-strong">KeysOfType</a>.
      </p>
    </section>

    <div class="mt-16 flex items-center justify-between border-t border-border pt-8">
      <span></span>
      <a href="/guide/core-concepts/" class="text-sm text-muted hover:text-text">
        Core concepts <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</GuideLayout>

