  {
    key: 'radar',
    svg: `<svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(100, 50)">
        <polygon points="0,-38 36,-11 22,30 -22,30 -36,-11" stroke="${grid}" stroke-width="1" fill="none"/>
        <polygon points="0,-28 27,-8 17,22 -17,22 -27,-8" stroke="${grid}" stroke-width="1" fill="none" opacity="0.6"/>
        <polygon points="0,-18 18,-6 11,15 -11,15 -18,-6" stroke="${grid}" stroke-width="1" fill="none" opacity="0.4"/>
        <polygon points="0,-34 30,-6 15,26 -18,20 -28,-4" fill="${accent}" fill-opacity="0.3" stroke="${accent}" stroke-width="1.5"/>
        <polygon points="0,-22 24,-10 20,18 -12,26 -20,-10" fill="${accent2}" fill-opacity="0.3" stroke="${accent2}" stroke-width="1.5"/>
      </g>
    </svg>`,
  },
];
---

<BaseLayout title={title}>
  <section class="mb-16">
    <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-brand-strong">Examples</p>
    <h1 class="mb-4 text-4xl font-semibold tracking-tight text-text sm:text-5xl">
      Chart type gallery
    </h1>
    <p class="max-w-[720px] text-lg leading-relaxed text-muted">
      Every chart Chartly ships, with live source code you can copy. Click any
      card to open the first example in that category, then explore variants
      from the sidebar.
    </p>
  </section>

  <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {exampleCategories.map((category) => {
      const thumb = thumbnails.find((t) => t.key === category.key);
      return (
        <a
          href={category.firstExampleHref}
          class="group flex flex-col overflow-hidden rounded-xl border border-border bg-panel/40 transition-all hover:border-brand-strong/60 hover:bg-panel"
        >
          <div class="flex h-40 w-full items-center justify-center border-b border-border bg-black p-4 transition-colors group-hover:bg-[#050505]">
            <div class="h-full w-full" set:html={thumb?.svg ?? ''} />
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h2 class="mb-1 text-lg font-semibold text-text transition-colors group-hover:text-brand-strong">
              {category.heading}
            </h2>
            <p class="mb-4 flex-1 text-sm text-muted">{category.tagline}</p>
            <div class="text-xs text-muted">
              {category.examples.length} example{category.examples.length === 1 ? '' : 's'}
              <span class="ml-2 text-brand-strong opacity-0 transition-opacity group-hover:opacity-100">
                &rarr;
              </span>
            </div>
          </div>
        </a>
      );
    })}
  </section>
</BaseLayout>
