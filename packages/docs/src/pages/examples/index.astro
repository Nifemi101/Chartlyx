---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { exampleCategories } from '../../data/examples';

const title = 'Examples · Chartly';

const accent = '#5eead4';
const accent2 = '#38bdf8';
const violet = '#a78bfa';
const pink = '#f472b6';
const grid = '#334155';

interface Thumbnail {
  key: string;
  svg: string;
}

const thumbnails: Thumbnail[] = [
  {
    key: 'line',
    svg: `<svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 80 H192 M8 60 H192 M8 40 H192 M8 20 H192" stroke="${grid}" stroke-width="1" stroke-dasharray="2 4" opacity="0.5"/>
      <path d="M8 70 C 30 20, 60 90, 90 45 C 120 20, 150 70, 192 30" stroke="${accent}" stroke-width="2" fill="none" stroke-linecap="round"/>
      <circle cx="8" cy="70" r="2.5" fill="${accent}"/>
      <circle cx="90" cy="45" r="2.5" fill="${accent}"/>
      <circle cx="192" cy="30" r="2.5" fill="${accent}"/>
    </svg>`,
  },
  {
    key: 'area',
    svg: `<svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="thumbAreaFade" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${accent}" stop-opacity="0.35"/>
          <stop offset="100%" stop-color="${accent}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="M8 80 H192 M8 60 H192 M8 40 H192 M8 20 H192" stroke="${grid}" stroke-width="1" stroke-dasharray="2 4" opacity="0.5"/>
