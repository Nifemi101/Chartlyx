      <rect x="14" y="52" width="22" height="40" fill="${accent2}"/>
      <rect x="14" y="34" width="22" height="18" fill="${accent}"/>
      <rect x="14" y="22" width="22" height="12" fill="${violet}"/>
      <rect x="52" y="42" width="22" height="50" fill="${accent2}"/>
      <rect x="52" y="24" width="22" height="18" fill="${accent}"/>
      <rect x="52" y="16" width="22" height="8" fill="${violet}"/>
      <rect x="90" y="58" width="22" height="34" fill="${accent2}"/>
      <rect x="90" y="40" width="22" height="18" fill="${accent}"/>
      <rect x="90" y="30" width="22" height="10" fill="${violet}"/>
      <rect x="128" y="36" width="22" height="56" fill="${accent2}"/>
