    </svg>`,
  },
  {
    key: 'bar',
    svg: `<svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 80 H192 M8 60 H192 M8 40 H192 M8 20 H192" stroke="${grid}" stroke-width="1" stroke-dasharray="2 4" opacity="0.5"/>
      <rect x="14" y="42" width="22" height="50" rx="3" fill="${accent2}"/>
      <rect x="52" y="18" width="22" height="74" rx="3" fill="${accent2}"/>
      <rect x="90" y="52" width="22" height="40" rx="3" fill="${accent2}"/>
      <rect x="128" y="26" width="22" height="66" rx="3" fill="${accent2}"/>
      <rect x="166" y="58" width="22" height="34" rx="3" fill="${accent2}"/>
