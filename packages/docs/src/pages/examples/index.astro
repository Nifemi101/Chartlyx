  {
    key: 'pie',
    svg: `<svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(100, 50)">
        <path d="M0,-38 A38,38 0 0,1 32.9,-19 L16.5,-9.5 A19,19 0 0,0 0,-19 Z" fill="${accent}"/>
        <path d="M32.9,-19 A38,38 0 0,1 16.5,32.9 L8.2,16.5 A19,19 0 0,0 16.5,-9.5 Z" fill="${accent2}"/>
        <path d="M16.5,32.9 A38,38 0 0,1 -32.9,19 L-16.5,9.5 A19,19 0 0,0 8.2,16.5 Z" fill="${violet}"/>
        <path d="M-32.9,19 A38,38 0 0,1 -32.9,-19 L-16.5,-9.5 A19,19 0 0,0 -16.5,9.5 Z" fill="${pink}"/>
        <path d="M-32.9,-19 A38,38 0 0,1 0,-38 L0,-19 A19,19 0 0,0 -16.5,-9.5 Z" fill="#fb923c"/>
