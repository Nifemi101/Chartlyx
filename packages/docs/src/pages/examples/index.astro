      <path d="M8 80 H192 M8 60 H192 M8 40 H192 M8 20 H192" stroke="${grid}" stroke-width="1" stroke-dasharray="2 4" opacity="0.5"/>
      <circle cx="18" cy="72" r="4" fill="${accent}" fill-opacity="0.85"/>
      <circle cx="38" cy="50" r="4" fill="${accent}" fill-opacity="0.85"/>
      <circle cx="58" cy="60" r="4" fill="${accent}" fill-opacity="0.85"/>
      <circle cx="80" cy="30" r="4" fill="${accent}" fill-opacity="0.85"/>
      <circle cx="102" cy="42" r="4" fill="${accent}" fill-opacity="0.85"/>
