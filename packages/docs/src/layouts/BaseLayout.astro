---
import '../styles/global.css';
const { title } = Astro.props;

const githubUrl = 'https://github.com/Nifemi101/Chartlyx/';
const npmUrl = 'https://www.npmjs.com/package/chartlyx';

const navItems = [
  { href: '/guide/', label: 'Guide' },
  { href: '/examples/', label: 'Examples' },
  { href: '/api/', label: 'API' },
  { href: npmUrl, label: 'npm', external: true },
  { href: githubUrl, label: 'GitHub', external: true },
];

const footerColumns = [
  {
    heading: 'Docs',
    links: [
      { href: '/guide/', label: 'Getting started' },
      { href: '/guide/core-concepts/', label: 'Core concepts' },
      { href: '/examples/', label: 'Examples' },
      { href: '/api/', label: 'API reference' },
    ],
  },
  {
    heading: 'Community',
    links: [
      { href: githubUrl, label: 'GitHub' },
      { href: npmUrl, label: 'npm' },
      { href: githubUrl + 'issues', label: 'Report an issue' },
      { href: githubUrl + 'discussions', label: 'Discussions' },
    ],
  },
  {
    heading: 'Project',
    links: [
      { href: '/guide/#roadmap', label: 'Roadmap' },
      { href: githubUrl + 'blob/main/CHANGELOG.md', label: 'Changelog' },
      { href: githubUrl + 'blob/main/LICENSE', label: 'License (MIT)' },
    ],
  },
];

const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="m-0 bg-bg text-text font-sans">
    <header class="sticky top-0 z-30 border-b border-border bg-panel/95 backdrop-blur-md">
      <nav
        class="mx-auto flex w-full max-w-[1180px] items-center justify-between gap-6 px-4 py-3 sm:min-h-16 sm:px-6 sm:py-0"
        aria-label="Primary navigation"
      >
        <a class="inline-flex items-center whitespace-nowrap text-lg font-extrabold tracking-tight text-brand" href="/" aria-label="Chartlyx home">
          chartlyx
        </a>

        <div class="hidden md:flex md:items-center md:gap-6">
          {navItems.map((item) => (
            <a
              class="text-sm font-semibold text-[#c7ccd5] transition-colors hover:text-brand-strong"
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
            >
              {item.label}
              {item.external && <span class="ml-1 text-[0.7em] opacity-60">&#8599;</span>}
            </a>
          ))}
        </div>

        <button
          id="mobile-menu-toggle"
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border text-text transition-colors hover:border-zinc-600 md:hidden"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path class="menu-open-icon" d="M4 6h16M4 12h16M4 18h16" />
            <path class="menu-close-icon hidden" d="M6 6l12 12M6 18L18 6" />
          </svg>
        </button>
      </nav>

      <div
        id="mobile-menu"
        class="hidden border-t border-border bg-panel md:hidden"
      >
        <ul class="mx-auto flex w-full max-w-[1180px] flex-col gap-1 px-4 py-4">
          {navItems.map((item) => (
            <li>
              <a
                class="flex items-center justify-between rounded-md px-3 py-2.5 text-base font-semibold text-[#c7ccd5] transition-colors hover:bg-panel-soft hover:text-brand-strong"
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >
                {item.label}
                {item.external && <span class="text-[0.85em] opacity-60">&#8599;</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>
    <main class="mx-auto w-full max-w-[1120px] px-4 pt-8 pb-16 sm:px-6 sm:pt-12 sm:pb-20 md:pt-[4.5rem]">
      <slot />
    </main>
    <footer class="border-t border-border bg-panel/40">
      <div class="mx-auto w-full max-w-[1120px] px-4 py-10 sm:px-6 sm:py-12">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-10 lg:grid-cols-[1.5fr_1fr_1fr_1fr]">
          <div class="sm:col-span-2 lg:col-span-1">
            <a class="inline-flex items-center whitespace-nowrap text-base font-extrabold tracking-tight text-brand" href="/" aria-label="Chartlyx home">
              chartlyx
            </a>
            <p class="mt-3 max-w-[320px] text-sm leading-relaxed text-muted">
              A composable charting library for React: typed, D3-powered, MIT licensed.
            </p>
          </div>
          {footerColumns.map((col) => (
            <div>
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-text">
                {col.heading}
              </h3>
              <ul class="flex flex-col gap-2">
                {col.links.map((link) => {
                  const isExternal = link.href.startsWith('http');
                  return (
                    <li>
                      <a
                        class="inline-flex items-center gap-1 text-sm text-muted transition-colors hover:text-text"
                        href={link.href}
                        target={isExternal ? '_blank' : undefined}
                        rel={isExternal ? 'noopener noreferrer' : undefined}
                      >
                        {link.label}
                        {isExternal && <span class="text-[0.7em] opacity-60">&#8599;</span>}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </div>
        <div class="mt-8 flex flex-col items-start gap-3 border-t border-border pt-6 text-xs text-muted sm:mt-10 sm:flex-row sm:items-center sm:justify-between">
          <div>
            &copy; {currentYear} Chartlyx &middot; MIT License &middot; v1.0.1
          </div>
          <div class="flex items-center gap-1.5">
            <span>Built with</span>
            <a class="font-medium text-text hover:text-brand-strong" href="https://react.dev/" target="_blank" rel="noopener noreferrer">React</a>
            <span>+</span>
            <a class="font-medium text-text hover:text-brand-strong" href="https://d3js.org/" target="_blank" rel="noopener noreferrer">D3</a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (!toggle || !menu) return;
        const openIcon = toggle.querySelector('.menu-open-icon');
        const closeIcon = toggle.querySelector('.menu-close-icon');

        const setState = (open) => {
          menu.classList.toggle('hidden', !open);
          openIcon?.classList.toggle('hidden', open);
          closeIcon?.classList.toggle('hidden', !open);
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        };

        toggle.addEventListener('click', () => {
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          setState(!isOpen);
        });

        // Close on link click so nav feels responsive
        menu.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => setState(false));
        });

        // Close if resized above md breakpoint
        const mq = window.matchMedia('(min-width: 768px)');
        mq.addEventListener('change', (e) => {
          if (e.matches) setState(false);
        });
      })();

      // Force sidebar <details> open on desktop so it can't get stuck closed
      (() => {
        const desktopMq = window.matchMedia('(min-width: 1024px)');
        const syncSidebars = () => {
          document.querySelectorAll('.sidebar-details').forEach((el) => {
            if (desktopMq.matches) el.setAttribute('open', '');
          });
        };
        syncSidebars();
        desktopMq.addEventListener('change', syncSidebars);
      })();
    </script>
  </body>
</html>
