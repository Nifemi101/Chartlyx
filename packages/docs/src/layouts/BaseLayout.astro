---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: #0f172a;
        color: #e2e8f0;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      a {
        color: #7dd3fc;
        text-decoration: none;
      }
      header {
        margin-bottom: 2rem;
      }
      header p {
        margin: 0.25rem 0 0;
        color: #94a3b8;
      }
      section {
        margin-bottom: 2rem;
      }
      code {
        background: rgba(148, 163, 184, 0.15);
        padding: 0.25rem 0.45rem;
        border-radius: 0.35rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <a href="/">
          <h1 style="margin:0;">Chartly</h1>
        </a>
        <p>{title}</p>
      </header>
      <slot />
    </main>
  </body>
</html>
