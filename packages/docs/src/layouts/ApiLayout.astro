---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

interface NavLink {
  label: string;
  href: string;
}
interface NavSection {
  heading: string;
  basePath: string;
  links: NavLink[];
}

const sidebar: NavSection[] = [
  {
    heading: 'Overview',
    basePath: '/api',
    links: [
      { label: 'Import & version', href: '/api/#imports' },
      { label: 'Quick reference', href: '/api/#reference' },
    ],
  },
  {
    heading: 'Components',
    basePath: '/api/components',
    links: [
      { label: 'ChartContainer', href: '/api/components/#chart-container' },
      { label: 'Line', href: '/api/components/#line' },
      { label: 'Area', href: '/api/components/#area' },
      { label: 'Bar', href: '/api/components/#bar' },
      { label: 'Scatter', href: '/api/components/#scatter' },
      { label: 'StackedBar', href: '/api/components/#stacked-bar' },
      { label: 'StackedArea', href: '/api/components/#stacked-area' },
      { label: 'XAxis', href: '/api/components/#xaxis' },
      { label: 'YAxis', href: '/api/components/#yaxis' },
      { label: 'CartesianGrid', href: '/api/components/#cartesian-grid' },
      { label: 'LinearGradient', href: '/api/components/#linear-gradient' },
      { label: 'Tooltip', href: '/api/components/#tooltip' },
      { label: 'Legend', href: '/api/components/#legend' },
      { label: 'PolarChartContainer', href: '/api/components/#polar-container' },
      { label: 'Pie', href: '/api/components/#pie' },
      { label: 'Radar', href: '/api/components/#radar' },
      { label: 'RadarGrid', href: '/api/components/#radar-grid' },
      { label: 'RadarAxes', href: '/api/components/#radar-axes' },
      { label: 'PolarTooltip', href: '/api/components/#polar-tooltip' },
    ],
  },
  {
    heading: 'Hooks',
    basePath: '/api/hooks',
    links: [
      { label: 'useChartContext', href: '/api/hooks/#use-chart-context' },
      { label: 'usePolarChartContext', href: '/api/hooks/#use-polar-chart-context' },
    ],
  },
  {
    heading: 'Helpers',
    basePath: '/api/helpers',
    links: [
      { label: 'stackSum', href: '/api/helpers/#stack-sum' },
      { label: 'pickColor', href: '/api/helpers/#pick-color' },
      { label: 'DEFAULT_STACK_COLORS', href: '/api/helpers/#default-stack-colors' },
      { label: 'DEFAULT_MARGIN', href: '/api/helpers/#default-margin' },
      { label: 'VERSION', href: '/api/helpers/#version' },
    ],
  },
  {
    heading: 'Types',
    basePath: '/api/types',
    links: [
      { label: 'ChartContainerProps', href: '/api/types/#chart-container-props' },
      { label: 'ChartContextValue', href: '/api/types/#chart-context-value' },
      { label: 'PolarChartContainerProps', href: '/api/types/#polar-container-props' },
      { label: 'PolarChartContextValue', href: '/api/types/#polar-context-value' },
      { label: 'Shape prop types', href: '/api/types/#shape-props' },
      { label: 'AxisProps', href: '/api/types/#axis-props' },
      { label: 'CartesianGridProps', href: '/api/types/#cartesian-grid-props' },
      { label: 'TooltipProps', href: '/api/types/#tooltip-props' },
      { label: 'LegendProps · LegendItem', href: '/api/types/#legend-props' },
      { label: 'LinearGradientProps', href: '/api/types/#linear-gradient-props' },
      { label: 'ShapeLabelRender', href: '/api/types/#shape-label-render' },
      { label: 'PieLabelRender', href: '/api/types/#pie-label-render' },
      { label: 'TooltipState · TooltipRender', href: '/api/types/#tooltip-state' },
      { label: 'PolarTooltipState · PolarTooltipRender', href: '/api/types/#polar-tooltip-state' },
      { label: 'TickValue · TickFormatter', href: '/api/types/#tick-formatter' },
      { label: 'CurveType', href: '/api/types/#curve-type' },
      { label: 'ScaleType · ScaleInput', href: '/api/types/#scale-type' },
      { label: 'Margin', href: '/api/types/#margin' },
      { label: 'KeysOfType', href: '/api/types/#keys-of-type' },
    ],
  },
];
---

<BaseLayout title={title}>
  <div class="mx-[-1.5rem] flex flex-col gap-8 lg:flex-row lg:gap-10">
    <aside class="lg:sticky lg:top-24 lg:h-[calc(100vh-8rem)] lg:w-64 lg:shrink-0 lg:overflow-y-auto">
      <nav class="guide-nav px-6 pb-8 lg:pl-6 lg:pr-2" aria-label="API navigation">
        {sidebar.map((section) => {
          const sectionActive = currentPath === section.basePath;
          return (
            <div class="mb-6">
              <a
                href={section.basePath + '/'}
                class={
                  sectionActive
                    ? 'mb-2 block text-[0.7rem] font-semibold uppercase tracking-wider text-brand-strong'
                    : 'mb-2 block text-[0.7rem] font-semibold uppercase tracking-wider text-text transition-colors hover:text-brand-strong'
                }
              >
                {section.heading}
              </a>
              <ul class="flex flex-col gap-0.5 border-l border-border">
                {section.links.map((link) => (
                  <li>
                    <a
                      class={
                        sectionActive
                          ? 'block -ml-px border-l-2 border-transparent pl-3 py-1 text-sm text-muted transition-colors hover:border-brand-strong hover:text-text'
                          : 'block -ml-px border-l-2 border-transparent pl-3 py-1 text-sm text-muted transition-colors hover:border-zinc-600 hover:text-text'
                      }
                      href={link.href}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </nav>
    </aside>

    <article class="min-w-0 flex-1 px-6 pb-16">
      <slot />
    </article>
  </div>
</BaseLayout>
