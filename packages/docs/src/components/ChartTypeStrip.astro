---
interface ChartType {
  name: string;
  svg: string;
}

const accent = '#5eead4';
const accent2 = '#38bdf8';
const grid = '#334155';

const chartTypes: ChartType[] = [
  {
    name: 'Line',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 30 L14 34 M2 30 L14 34" stroke="${grid}" stroke-width="1" opacity="0.4"/>
      <path d="M2 32 H62 M2 22 H62 M2 12 H62" stroke="${grid}" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>
      <path d="M2 30 C 12 8, 20 34, 32 18 C 42 6, 48 26, 62 8" stroke="${accent}" stroke-width="1.5" fill="none"/>
    </svg>`,
  },
  {
    name: 'Bar',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 32 H62 M2 22 H62 M2 12 H62" stroke="${grid}" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>
      <rect x="4" y="14" width="8" height="22" rx="1.5" fill="${accent2}"/>
      <rect x="16" y="4" width="8" height="32" rx="1.5" fill="${accent2}"/>
      <rect x="28" y="20" width="8" height="16" rx="1.5" fill="${accent2}"/>
      <rect x="40" y="10" width="8" height="26" rx="1.5" fill="${accent2}"/>
      <rect x="52" y="24" width="8" height="12" rx="1.5" fill="${accent2}"/>
    </svg>`,
  },
  {
    name: 'Donut',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(32,20)">
        <path d="M0,-16 A16,16 0 0,1 12.94,9.41 L6.47,4.71 A8,8 0 0,0 0,-8 Z" fill="${accent}"/>
        <path d="M12.94,9.41 A16,16 0 0,1 -9.41,12.94 L-4.71,6.47 A8,8 0 0,0 6.47,4.71 Z" fill="${accent2}"/>
        <path d="M-9.41,12.94 A16,16 0 0,1 -15.22,-4.94 L-7.61,-2.47 A8,8 0 0,0 -4.71,6.47 Z" fill="#a78bfa"/>
        <path d="M-15.22,-4.94 A16,16 0 0,1 0,-16 L0,-8 A8,8 0 0,0 -7.61,-2.47 Z" fill="#f472b6"/>
      </g>
    </svg>`,
  },
  {
    name: 'Radar',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(32,20)">
        <polygon points="0,-16 15,-5 9,13 -9,13 -15,-5" stroke="${grid}" stroke-width="1" fill="none"/>
        <polygon points="0,-10 9,-3 6,8 -6,8 -9,-3" stroke="${grid}" stroke-width="1" fill="none" opacity="0.6"/>
        <polygon points="0,-14 12,-2 5,10 -8,9 -11,-6" fill="${accent}" fill-opacity="0.3" stroke="${accent}" stroke-width="1.5"/>
      </g>
    </svg>`,
  },
  {
    name: 'Stacked',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 32 H62 M2 22 H62 M2 12 H62" stroke="${grid}" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>
      <rect x="6" y="24" width="10" height="12" fill="${accent2}"/>
      <rect x="6" y="14" width="10" height="10" fill="#10b981"/>
      <rect x="6" y="8" width="10" height="6" fill="#f59e0b"/>
      <rect x="24" y="20" width="10" height="16" fill="${accent2}"/>
      <rect x="24" y="10" width="10" height="10" fill="#10b981"/>
      <rect x="24" y="4" width="10" height="6" fill="#f59e0b"/>
      <rect x="42" y="26" width="10" height="10" fill="${accent2}"/>
      <rect x="42" y="16" width="10" height="10" fill="#10b981"/>
      <rect x="42" y="10" width="10" height="6" fill="#f59e0b"/>
    </svg>`,
  },
  {
    name: 'Scatter',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 32 H62 M2 22 H62 M2 12 H62" stroke="${grid}" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>
      <circle cx="8" cy="30" r="2.5" fill="${accent}"/>
      <circle cx="16" cy="20" r="2.5" fill="${accent}"/>
      <circle cx="24" cy="26" r="2.5" fill="${accent}"/>
      <circle cx="30" cy="12" r="2.5" fill="${accent}"/>
      <circle cx="38" cy="18" r="2.5" fill="${accent}"/>
      <circle cx="46" cy="8" r="2.5" fill="${accent}"/>
      <circle cx="54" cy="16" r="2.5" fill="${accent}"/>
      <circle cx="58" cy="28" r="2.5" fill="${accent}"/>
    </svg>`,
  },
  {
    name: 'Composed',
    svg: `<svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 32 H62 M2 22 H62 M2 12 H62" stroke="${grid}" stroke-width="1" stroke-dasharray="2 3" opacity="0.5"/>
      <rect x="4" y="22" width="7" height="14" fill="${accent2}" fill-opacity="0.5"/>
      <rect x="15" y="12" width="7" height="24" fill="${accent2}" fill-opacity="0.5"/>
      <rect x="26" y="18" width="7" height="18" fill="${accent2}" fill-opacity="0.5"/>
      <rect x="37" y="8" width="7" height="28" fill="${accent2}" fill-opacity="0.5"/>
      <rect x="48" y="16" width="7" height="20" fill="${accent2}" fill-opacity="0.5"/>
      <path d="M7 20 L18 24 L29 14 L40 20 L51 12" stroke="${accent}" stroke-width="1.5" fill="none"/>
    </svg>`,
  },
];
---

<section class="mb-16" aria-label="Chart types">
  <p class="mb-6 max-w-[620px] text-base text-text">
    Line, Bar, Donut, Radar, Stacked, Scatter, Composed — one library.
  </p>
  <div class="strip -mx-6 flex snap-x snap-mandatory gap-4 overflow-x-auto px-6 pb-2">
    {chartTypes.map((chart) => (
      <div class="flex w-[160px] shrink-0 snap-start flex-col items-center gap-3 rounded-lg border border-border bg-panel p-4">
        <div class="h-[70px] w-full" set:html={chart.svg} />
        <span class="text-sm font-semibold text-text">{chart.name}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .strip {
    scrollbar-width: none;
    -ms-overflow-style: none;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 24px,
      black calc(100% - 32px),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 24px,
      black calc(100% - 32px),
      transparent 100%
    );
  }
  .strip::-webkit-scrollbar {
    display: none;
  }
</style>